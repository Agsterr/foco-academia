# Banco
POSTGRES_DB=academia
POSTGRES_USER=academia
POSTGRES_PASSWORD=troque-esta-senha

# API
JWT_SECRET=gere-uma-chave-segura-com-pelo-menos-32-caracteres
CORS_ORIGINS=https://academia.focodev.com.br,https://www.academia.focodev.com.br

# Frontends (vazio = mesma origem via nginx)
PUBLIC_API_URL=

# HTTP local (produção: nginx na porta 80 com cloudflared host network)
HTTP_PORT=8088

# Cloudflare Tunnel (opcional — ative com: docker compose --profile tunnel up -d)
CLOUDFLARED_TUNNEL_TOKEN=

# Seed inicial da API (apenas primeira subida / ambiente de desenvolvimento)
SEED_ADMIN_PASSWORD=
SEED_INSTRUTOR_PASSWORD=
SEED_ALUNO_PASSWORD=
